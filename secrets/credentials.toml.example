# omni-me-server credentials (PUBLIC, bank-free template).
#
# Copy this file to `secrets/credentials.toml` and uncomment the sections you
# need. With everything commented out the server boots zero-config (no
# extractor, no auto-import sources) — that is a supported, tested state.
#
# This file is mounted read-only into the container at
# /config/omni-me/credentials.toml. Bank-specific sections live ONLY in the
# private overlay and never appear in this public template.
#
# Secret handling: the real `secrets/credentials.toml` is gitignored; in
# production lock it down (chown to the container uid + chmod 600) — see
# DEPLOY.md.

# --- Gemini document extractor -------------------------------------------
# API key for the multimodal extractor (receipts, statements, paystubs).
# The GEMINI_API_KEY env var (set via .env) takes precedence over this — use
# whichever you prefer. Without either, handlers fall back to NullExtractor.
# [gemini]
# api_key = "your-gemini-api-key"

# --- IMAP mailbox pollers -------------------------------------------------
# One table per mailbox; the key (e.g. "gmail_personal") is a label you choose.
# Use an APP PASSWORD, never your main login. `watched_label` is the folder /
# label the poller scans (defaults to "omni-me").
# [imap.gmail_personal]
# host = "imap.gmail.com"
# port = 993
# account = "you@gmail.com"
# app_password = "abcd efgh ijkl mnop"
# watched_label = "omni-me"

# --- Bring-your-own text LLM (optional) -----------------------------------
# Route the *text* LLM to any OpenAI-compatible endpoint. Omit for the Gemini
# default. Set vision = true to also send images there (only if it supports it).
# [llm]
# provider = "openai_compatible"
# base_url = "http://localhost:11434/v1"
# model = "llama3.1"
# api_key = "sk-local-or-empty"
# vision = false

# --- Named secrets (optional) ---------------------------------------------
# name -> secret value, referenced by name from sources.toml (keeps API keys
# out of the non-secret sources config).
# [secrets]
# some_api = "secret-value"
