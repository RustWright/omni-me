# Optional environment for omni-me-server (Phase 2 task 2.1).
# Copy to `.env`; docker-compose loads it if present. Everything here is
# optional — the server boots zero-config with none of it set.

# Gemini multimodal extractor key. Takes precedence over [gemini].api_key in
# credentials.toml. Leave unset to fall back to NullExtractor.
# GEMINI_API_KEY=your-gemini-api-key

# Log verbosity (tracing EnvFilter syntax). When unset the server defaults to
# "omni_me_server=debug,omni_me_core=info,tower_http=debug".
# RUST_LOG=info
